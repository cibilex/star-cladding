---
import MobileMenu from "@/components/react/MobileMenu";
import Icon from "@/components/Icon.astro";
import Logo from "@/components/Logo.astro";
import { company, nav, social } from "@/data/site";

interface Props {
  /** "light" renders dark links/pills from the start — use over a light hero. */
  variant?: "dark" | "light";
}
const { variant = "dark" } = Astro.props;
---

<header
  id="main-nav"
  class:list={[
    "fixed top-0 z-50 w-full transition-all duration-300",
    variant === "light" && "on-light",
  ]}
>
  <!-- contact topbar: navy strip, collapses on scroll (see .header-topbar in global.css) -->
  <div
    class="header-topbar flex items-center justify-between gap-4 bg-primary px-margin-mobile text-white md:px-margin-desktop"
  >
    <div class="flex min-w-0 items-center gap-3 md:gap-5">
      <a
        href={company.phoneHref}
        class="flex shrink-0 items-center gap-2 text-label text-white/60 transition-colors hover:text-white"
      >
        <Icon name="phone" class="size-3.5 text-aluminum-silver" />
        <span>{company.phone}</span>
      </a>

      <span class="hidden h-3.5 w-px bg-white/15 lg:block" aria-hidden="true"
      ></span>

      <a
        href={company.mapsLink}
        target="_blank"
        rel="noopener"
        class="hidden min-w-0 items-center gap-2 text-label text-white/60 transition-colors hover:text-white lg:flex"
      >
        <Icon name="map-pin" class="size-3.5 shrink-0 text-aluminum-silver" />
        <span class="truncate">{company.address}</span>
      </a>
    </div>

    <div class="flex shrink-0 items-center gap-1.5">
      <a
        href={company.whatsapp}
        target="_blank"
        rel="noopener"
        class="flex size-7 items-center justify-center rounded-full text-white/60 transition-colors hover:bg-white/10 hover:text-[#25D366]"
        aria-label="WhatsApp"
      >
        <svg
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-3.5"
          aria-hidden="true"
        >
          <path
            d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.02zM12.04 20.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24a8.2 8.2 0 0 1 8.23 8.25c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"
          ></path>
        </svg>
      </a>

      {
        social.map((item) => (
          <>
            <span class="h-3.5 w-px bg-white/15" aria-hidden="true" />
            <a
              href={item.href}
              target="_blank"
              rel="noopener"
              class:list={[
                "flex size-7 items-center justify-center rounded-full text-white/60 transition-colors hover:bg-white/10",
                item.icon === "instagram"
                  ? "hover:text-[#E4405F]"
                  : "hover:text-white",
              ]}
              aria-label={item.label}
            >
              <Icon name={item.icon} class="size-3.5" />
            </a>
          </>
        ))
      }
    </div>
  </div>

  <!-- main nav -->
  <nav
    class="flex h-16 w-full items-center justify-between px-margin-mobile md:px-margin-desktop"
  >
    <Logo size="lg" hideTextOnMobile />

    <!-- Desktop links (static, 0 JS) -->
    <div class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="header-link text-label font-semibold uppercase tracking-widest"
          >
            {item.label}
          </a>
        ))
      }
      <span class="header-link text-label font-bold">TR</span>
      <!-- CTA: gradient pill -->
      <a
        href="/#iletisim"
        class="group inline-flex h-10 items-center gap-2 rounded-full bg-gradient-to-r from-vibrant-steel-blue to-steel-blue px-6 text-label font-semibold uppercase tracking-widest text-white shadow-md shadow-vibrant-steel-blue/25 ring-1 ring-inset ring-white/15 transition-all hover:shadow-lg hover:shadow-vibrant-steel-blue/40 hover:brightness-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        TEKLİF AL
        <Icon
          name="arrow-right"
          class="size-4 transition-transform group-hover:translate-x-0.5"
        />
      </a>
    </div>

    <!-- Mobile drawer (Motion island) -->
    <MobileMenu client:load />
  </nav>
</header>
