---
import ContactForm from "@/components/react/ContactForm";
import Icon from "@/components/Icon.astro";
import { company } from "@/data/site";
import type { IconName } from "@/components/icon-registry";

/**
 * Contact V1 — "Aurora Split Panel" (CSS only).
 * Navy section with HeroLight motifs flipped to dark: drifting aurora blobs,
 * deterministic meteor shower, faint masked architectural grid. Left column
 * carries the headline + icon-chip contact items + WhatsApp CTA; right column
 * holds the ContactForm island inside a frosted glass card with an inner white
 * surface (the form is styled for light backgrounds). Mobile leads with a
 * 3-button quick-action row (Ara / WhatsApp / Yol Tarifi).
 */
interface Props {
  sectionId?: string;
}
const { sectionId = "iletisim" } = Astro.props;

const contactItems: {
  icon: IconName;
  label: string;
  value: string;
  href?: string;
}[] = [
  {
    icon: "phone",
    label: "TELEFON",
    value: company.phone,
    href: company.phoneHref,
  },
  {
    icon: "mail",
    label: "E-POSTA",
    value: company.email,
    href: `mailto:${company.email}`,
  },
  {
    icon: "map-pin",
    label: "ADRES",
    value: company.address,
    href: company.mapsLink,
  },
  { icon: "clock", label: "ÇALIŞMA SAATLERİ", value: company.hours },
];

const quickActions: {
  icon: IconName;
  label: string;
  href: string;
  external?: boolean;
}[] = [
  { icon: "phone", label: "Ara", href: company.phoneHref },
  {
    icon: "message-circle",
    label: "WhatsApp",
    href: company.whatsapp,
    external: true,
  },
  {
    icon: "map-pin",
    label: "Yol Tarifi",
    href: company.mapsLink,
    external: true,
  },
];

// Meteor placements — FIXED values (deterministic, parallel-build safe).
const meteors = [
  { top: "6%", left: "10%", delay: "0s", duration: "6.5s" },
  { top: "30%", left: "38%", delay: "2.4s", duration: "8s" },
  { top: "12%", left: "66%", delay: "4.6s", duration: "7s" },
  { top: "42%", left: "88%", delay: "1.3s", duration: "9s" },
];
---

<section
  id={sectionId}
  class="relative overflow-hidden bg-primary py-section-gap text-white"
>
  <!-- ambient background: aurora blobs + masked grid + meteors -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="aurora absolute -right-24 -top-32 h-[460px] w-[460px] rounded-full bg-vibrant-steel-blue/25 blur-3xl"
    >
    </div>
    <div
      class="aurora aurora-2 absolute -left-40 top-1/3 h-[420px] w-[420px] rounded-full bg-steel-blue/20 blur-3xl"
    >
    </div>
    <div
      class="aurora aurora-3 absolute -bottom-32 left-1/2 h-80 w-80 rounded-full bg-aluminum-silver/10 blur-3xl"
    >
    </div>
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);"
    >
    </div>
    {
      meteors.map((m) => (
        <span
          class="meteor"
          style={`top:${m.top};left:${m.left};animation-delay:${m.delay};animation-duration:${m.duration};`}
        />
      ))
    }
  </div>

  <div
    class="relative z-10 mx-auto max-w-7xl px-margin-mobile md:px-margin-desktop"
  >
    <!-- mobile quick actions: call / whatsapp / directions -->
    <div class="reveal mb-12 grid grid-cols-3 gap-3 md:hidden">
      {
        quickActions.map((action) => (
          <a
            href={action.href}
            {...(action.external ? { target: "_blank", rel: "noopener" } : {})}
            class="flex min-h-[64px] flex-col items-center justify-center gap-1.5 rounded-xl border border-white/15 bg-white/5 py-3 text-white transition-colors hover:border-vibrant-steel-blue/60 hover:bg-white/10 active:bg-white/15"
          >
            <Icon name={action.icon} class="size-5 text-aluminum-silver" />
            <span class="text-label font-semibold uppercase tracking-widest">
              {action.label}
            </span>
          </a>
        ))
      }
    </div>

    <div class="grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-gutter lg:gap-20">
      <!-- left: headline + contact chips + whatsapp cta -->
      <div>
        <span class="reveal mb-6 inline-flex items-center gap-4">
          <span class="h-px w-12 bg-vibrant-steel-blue" aria-hidden="true"
          ></span>
          <span
            class="text-label uppercase tracking-[0.25em] text-aluminum-silver"
            >İletişim</span
          >
        </span>

        <h2
          class="reveal mb-6 text-display-mobile font-extrabold md:text-display-lg"
          style="transition-delay: 100ms;"
        >
          Hadi, <span class="shimmer-text">kalıcı</span> bir şeyler inşa edelim.
        </h2>

        <p
          class="reveal mb-12 max-w-md text-body-lg text-white/70"
          style="transition-delay: 200ms;"
        >
          Projeniz için ücretsiz keşif ve teklif alın — en kısa sürede dönüş
          yapıyoruz.
        </p>

        <ul class="space-y-6">
          {
            contactItems.map((item, i) => (
              <li class="reveal" style={`transition-delay: ${250 + i * 75}ms;`}>
                <div class="group flex items-start gap-4">
                  <span class="flex size-11 shrink-0 items-center justify-center rounded-xl border border-white/15 bg-white/10 text-aluminum-silver transition-all duration-300 group-hover:text-white group-hover:ring-2 group-hover:ring-vibrant-steel-blue/60 group-hover:shadow-[0_0_24px_rgba(45,90,136,0.6)]">
                    <Icon name={item.icon} class="size-5" />
                  </span>
                  <div class="pt-0.5">
                    <p class="mb-1 text-label uppercase tracking-widest text-white/50">
                      {item.label}
                    </p>
                    {item.href ? (
                      <a
                        href={item.href}
                        {...(item.href.startsWith("http")
                          ? { target: "_blank", rel: "noopener" }
                          : {})}
                        class="inline-block py-1 text-body-lg text-white transition-colors hover:text-aluminum-silver"
                      >
                        {item.value}
                      </a>
                    ) : (
                      <p class="text-body-lg text-white">{item.value}</p>
                    )}
                  </div>
                </div>
              </li>
            ))
          }
        </ul>

        <a
          href={company.whatsapp}
          target="_blank"
          rel="noopener"
          class="reveal shimmer-btn mt-12 inline-flex min-h-[52px] items-center gap-3 rounded-full bg-vibrant-steel-blue px-8 py-4 text-label font-bold uppercase tracking-widest text-white shadow-lg shadow-vibrant-steel-blue/30 transition-transform hover:-translate-y-0.5"
          style="transition-delay: 550ms;"
        >
          <Icon name="message-circle" class="size-5" />
          WhatsApp'tan Yaz
          <Icon name="arrow-up-right" class="size-4" />
        </a>
      </div>

      <!-- right: form in frosted glass card with inner light surface -->
      <div class="reveal" style="transition-delay: 300ms;">
        <div
          class="rounded-2xl border border-white/20 bg-white/10 p-2.5 shadow-2xl shadow-black/30 backdrop-blur-xl sm:p-3"
        >
          <div class="overflow-hidden rounded-xl bg-surface">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* aurora blobs drift slowly; delays stagger the three layers */
  @keyframes aurora-drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.7;
    }
    50% {
      transform: translate3d(32px, -24px, 0) scale(1.12);
      opacity: 1;
    }
  }
  .aurora {
    animation: aurora-drift 14s ease-in-out infinite;
  }
  .aurora-2 {
    animation-delay: -5s;
  }
  .aurora-3 {
    animation-delay: -9s;
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora {
      animation: none;
    }
  }
</style>
