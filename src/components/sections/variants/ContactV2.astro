---
import ContactForm from "@/components/react/ContactForm";
import Icon from "@/components/Icon.astro";
import { company } from "@/data/site";
import type { IconName } from "@/components/icon-registry";

/**
 * Contact V2 — "Floating Card on Light" (CSS only).
 * Light bg-surface section with a faint architectural grid backdrop and a
 * text-gradient-steel heading. One elevated floating card wrapped in an
 * animated conic-gradient ring border (HeroLight CTA technique: overflow-hidden
 * wrapper + spinning conic gradient at inset-[-1000%] + inner card). Inside:
 * the ContactForm island next to a compact navy info column
 * (phone / email / address / hours + WhatsApp). Single column on mobile.
 */
interface Props {
  sectionId?: string;
}
const { sectionId = "iletisim" } = Astro.props;

const infoItems: { icon: IconName; label: string; value: string; href?: string }[] = [
  { icon: "phone", label: "TELEFON", value: company.phone, href: company.phoneHref },
  { icon: "mail", label: "E-POSTA", value: company.email, href: `mailto:${company.email}` },
  { icon: "map-pin", label: "ADRES", value: company.address, href: company.mapsLink },
  { icon: "clock", label: "ÇALIŞMA SAATLERİ", value: company.hours },
];
---

<section id={sectionId} class="relative overflow-hidden bg-surface py-section-gap">
  <!-- ambient background: masked grid + soft glows -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(to right, rgba(26,40,59,0.045) 1px, transparent 1px), linear-gradient(to bottom, rgba(26,40,59,0.045) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
    >
    </div>
    <div class="absolute -left-24 top-0 h-80 w-80 rounded-full bg-vibrant-steel-blue/10 blur-3xl"></div>
    <div class="absolute -bottom-24 -right-24 h-96 w-96 rounded-full bg-steel-blue/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-margin-mobile md:px-margin-desktop">
    <!-- heading -->
    <div class="mx-auto mb-14 max-w-2xl text-center md:mb-20">
      <span class="reveal mb-6 inline-flex items-center gap-4">
        <span class="h-px w-12 bg-vibrant-steel-blue" aria-hidden="true"></span>
        <span class="text-label uppercase tracking-[0.25em] text-on-surface-variant">İletişim</span>
        <span class="h-px w-12 bg-vibrant-steel-blue" aria-hidden="true"></span>
      </span>
      <h2
        class="reveal text-display-mobile font-extrabold text-primary md:text-display-lg"
        style="transition-delay: 100ms;"
      >
        Projenizi <span class="text-gradient-steel">Konuşalım</span>
      </h2>
      <p
        class="reveal mt-5 text-body-lg text-on-surface-variant"
        style="transition-delay: 200ms;"
      >
        Formu doldurun, ücretsiz keşif için en kısa sürede size dönelim — ya da tek
        dokunuşla arayın.
      </p>
    </div>

    <!-- floating card with animated conic ring border -->
    <div class="reveal mx-auto max-w-5xl" style="transition-delay: 300ms;">
      <div class="float-card relative overflow-hidden rounded-3xl p-[1.5px] shadow-2xl shadow-vibrant-steel-blue/20">
        <span
          class="absolute inset-[-1000%] animate-[spin_6s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,rgba(45,90,136,0.12)_35%,rgba(45,90,136,0.9)_50%,rgba(45,90,136,0.12)_65%)] motion-reduce:animate-none"
          aria-hidden="true"></span>

        <div class="relative grid overflow-hidden rounded-[calc(1.5rem-1.5px)] bg-white md:grid-cols-5">
          <!-- form -->
          <div class="md:col-span-3">
            <ContactForm client:visible />
          </div>

          <!-- compact info column -->
          <div class="relative overflow-hidden bg-primary p-8 text-white md:col-span-2 md:p-10">
            <div
              class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-vibrant-steel-blue/25 blur-3xl"
              aria-hidden="true"
            >
            </div>

            <div class="relative">
              <p class="mb-8 font-display text-headline font-bold">Bize Ulaşın</p>

              <ul class="space-y-6">
                {
                  infoItems.map((item) => (
                    <li class="flex items-start gap-3.5">
                      <span class="flex size-10 shrink-0 items-center justify-center rounded-lg border border-white/15 bg-white/10 text-aluminum-silver">
                        <Icon name={item.icon} class="size-4" />
                      </span>
                      <div class="pt-0.5">
                        <p class="mb-0.5 text-label uppercase tracking-widest text-white/50">{item.label}</p>
                        {item.href ? (
                          <a
                            href={item.href}
                            {...(item.href.startsWith("http") ? { target: "_blank", rel: "noopener" } : {})}
                            class="inline-block py-0.5 text-sm font-medium text-white transition-colors hover:text-aluminum-silver"
                          >
                            {item.value}
                          </a>
                        ) : (
                          <p class="text-sm font-medium text-white">{item.value}</p>
                        )}
                      </div>
                    </li>
                  ))
                }
              </ul>

              <a
                href={company.whatsapp}
                target="_blank"
                rel="noopener"
                class="shimmer-btn mt-10 inline-flex min-h-[48px] w-full items-center justify-center gap-2.5 rounded-full bg-vibrant-steel-blue px-6 py-3.5 text-label font-bold uppercase tracking-widest text-white transition-transform hover:-translate-y-0.5"
              >
                <Icon name="message-circle" class="size-5" />
                WhatsApp'tan Yaz
              </a>

              <p class="mt-6 flex items-center gap-2 text-label uppercase tracking-widest text-white/50">
                <Icon name="shield-check" class="size-4 text-aluminum-silver" />
                Ücretsiz keşif &amp; teklif
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* gentle levitation for the card — subtle, premium */
  @keyframes card-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }
  .float-card {
    animation: card-float 7s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .float-card {
      animation: none;
    }
  }
</style>
