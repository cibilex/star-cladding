---
import { getImage } from "astro:assets";
import { projects } from "@/data/site";
import { resolveImage } from "@/data/images";
import Icon from "@/components/Icon.astro";
import ProjectsRail from "@/components/react/variants/ProjectsRail";

/**
 * Projects — "Cinematic Rail".
 * Deep-navy section; the heading is static (0 JS) and the rail below is a
 * Motion island (client:visible): draggable + snapping horizontal cards,
 * progress bar and prev/next arrows. Photos are optimized here with
 * getImage() and passed to the island as plain URL strings (serializable).
 */
const railProjects = await Promise.all(
  projects.map(async (project) => {
    const img = resolveImage(project.image);
    const optimized = img
      ? await getImage({ src: img, width: 1200, format: "webp" })
      : null;
    return { ...project, image: optimized?.src ?? null };
  }),
);
---

<section id="projeler" class="overflow-hidden bg-primary py-section-gap">
  <div
    class="mb-12 flex flex-wrap items-end justify-between gap-6 px-margin-mobile md:mb-16 md:px-margin-desktop"
  >
    <div>
      <p
        class="reveal mb-3 flex items-center gap-3 text-label uppercase tracking-[0.25em] text-aluminum-silver"
      >
        <span class="h-px w-10 bg-vibrant-steel-blue" aria-hidden="true"></span>
        Seçkin Projeler
      </p>
      <h2
        class="reveal text-headline font-extrabold text-white md:text-display-lg"
        style="transition-delay: 100ms;"
      >
        Yapılarımız <span class="text-white/50">Konuşsun</span>
      </h2>
    </div>
    <a
      href="/projeler"
      class="reveal group inline-flex items-center gap-2 border-b border-white/40 pb-1 text-label font-semibold uppercase tracking-widest text-white transition-colors hover:border-white"
      style="transition-delay: 200ms;"
    >
      Tüm Projeler
      <Icon
        name="arrow-right"
        class="size-4 transition-transform group-hover:translate-x-1"
      />
    </a>
  </div>

  <ProjectsRail client:visible projects={railProjects} />
</section>
