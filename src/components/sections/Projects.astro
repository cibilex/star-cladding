---
import { projects } from "@/data/site";
import Icon from "@/components/Icon.astro";
// Home preview: show the first 3, link out to the full page.
const preview = projects.slice(0, 3);
---

<section id="projeler" class="overflow-hidden px-margin-mobile py-section-gap md:px-margin-desktop">
  <div class="mb-12 flex flex-wrap items-end justify-between gap-6">
    <div>
      <p class="mb-2 text-label font-semibold uppercase tracking-widest text-vibrant-steel-blue">
        Seçkin Projeler
      </p>
      <h2 class="text-headline text-primary">Projelerimiz</h2>
    </div>
    <a
      href="/projeler"
      class="inline-flex items-center gap-2 border-b border-vibrant-steel-blue pb-1 text-label font-semibold uppercase tracking-widest text-vibrant-steel-blue"
    >
      Tüm Projeler
      <Icon name="arrow-right" class="size-4" />
    </a>
  </div>

  <!-- horizontal scroll showcase (swipe on mobile) -->
  <div class="no-scrollbar flex gap-gutter overflow-x-auto pb-10">
    {
      preview.map((project, i) => (
        <a
          href={`/projeler/${project.slug}`}
          class="reveal group min-w-[80vw] md:min-w-[40vw]"
          style={`transition-delay: ${i * 150}ms;`}
        >
          <div class="mb-6 h-[480px] overflow-hidden bg-surface-container">
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-graphite to-steel-blue text-white/30">
                <Icon name="building" class="size-16" />
              </div>
            )}
          </div>
          <h3 class="text-body-lg font-bold text-primary">{project.title}</h3>
          <p class="text-label uppercase tracking-widest text-on-surface-variant">
            {project.category} · {project.location}
          </p>
        </a>
      ))
    }
  </div>
</section>
