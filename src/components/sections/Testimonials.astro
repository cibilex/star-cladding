---
import { testimonials } from "@/data/site";
import Icon from "@/components/Icon.astro";
---

<section id="yorumlar" class="bg-surface-container-low px-margin-mobile py-section-gap md:px-margin-desktop">
  <div class="mx-auto mb-20 max-w-7xl text-center">
    <p class="mb-2 text-label font-semibold uppercase tracking-widest text-vibrant-steel-blue">
      Kanıtlanmış Performans
    </p>
    <h2 class="text-headline text-primary">Müşteri Yorumları</h2>
  </div>

  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-gutter md:grid-cols-3">
    {
      testimonials.map((t, i) => (
        <figure
          class="reveal flex h-full flex-col bg-surface p-10"
          style={`transition-delay: ${i * 150}ms;`}
        >
          <div class="mb-4 flex gap-1 text-vibrant-steel-blue">
            {[0, 1, 2, 3, 4].map(() => (
              <Icon name="star" class="size-5" fill />
            ))}
          </div>
          <blockquote class="mb-8 flex-grow italic text-on-surface-variant">
            “{t.quote}”
          </blockquote>
          <figcaption class="flex items-center gap-4 border-t border-outline-variant pt-6">
            <div class="flex h-10 w-10 items-center justify-center bg-surface-container font-bold text-primary">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="text-label font-bold text-primary">{t.name}</p>
              <p class="text-[10px] uppercase tracking-widest text-on-surface-variant">
                {t.role}
              </p>
            </div>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
