---
import { Image } from "astro:assets";
import Icon from "@/components/Icon.astro";
import { company, nav, social } from "@/data/site";
import logo from "@/assets/images/logo.png";
const year = new Date().getFullYear();
---

<!--
  Minimalist footer. One slim row (brand · nav · socials/lang), a hairline,
  one slim bottom row (copyright · address/phone). Quote CTA lives as a
  plain text link in the nav row so goal #5 (reachable from every section)
  still holds.
-->
<footer
  class="border-t border-outline-variant bg-surface-container-low px-margin-mobile py-10 md:px-margin-desktop md:py-12"
>
  <div class="mx-auto max-w-7xl">
    <div
      class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between"
    >
      <a href="/" class="flex shrink-0 items-center gap-3" aria-label={company.name}>
        <Image
          src={logo}
          alt="Star Alüminyum logo"
          width={64}
          height={64}
          class="h-8 w-8 object-contain"
        />
        <span class="font-display text-lg font-bold tracking-tight text-primary">
          {company.name}
        </span>
      </a>

      <nav class="flex flex-wrap items-center gap-x-7 gap-y-3 md:gap-x-8">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-on-surface-variant transition-colors hover:text-vibrant-steel-blue"
            >
              {item.label}
            </a>
          ))
        }
        <a
          href="/#iletisim"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-vibrant-steel-blue transition-colors hover:text-primary"
        >
          Teklif Al
          <Icon name="arrow-right" class="size-3.5" />
        </a>
      </nav>

      <div class="flex shrink-0 items-center gap-4">
        {
          social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={s.label}
              class="flex size-9 items-center justify-center rounded-lg text-on-surface-variant transition-colors hover:text-vibrant-steel-blue"
            >
              <Icon name={s.icon} class="size-5" />
            </a>
          ))
        }
        <span class="h-4 w-px bg-outline-variant" aria-hidden="true"></span>
        <div class="flex items-center gap-3 text-label">
          <span class="font-bold text-primary">TR</span>
          <span class="cursor-pointer text-outline hover:text-primary">EN</span>
        </div>
      </div>
    </div>

    <div
      class="mt-8 flex flex-col-reverse items-center justify-between gap-3 border-t border-outline-variant pt-6 text-center text-label text-outline md:flex-row md:text-left"
    >
      <p>© {year} {company.legalName}. Tüm hakları saklıdır.</p>
      <p>{company.address} · {company.phone}</p>
    </div>
  </div>
</footer>
