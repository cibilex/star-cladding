---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Contact from "@/components/sections/Contact.astro";
import PageHero from "@/components/PageHero.astro";
import Icon from "@/components/Icon.astro";
import { projects } from "@/data/site";
---

<Layout
  title="Projelerimiz | STAR ALÜMİNYUM"
  description="Tamamladığımız cam cephe, kompozit panel ve korkuluk projeleri. Star Alüminyum referansları."
>
  <Header />
  <main>
    <PageHero
      kicker="Referanslarımız"
      title="Projelerimiz"
      subtitle="Tamamladığımız cephe işlerinden bir seçki. Her proje, milimetrik hassasiyetle hayata geçirildi."
      crumbs={[{ label: "Anasayfa", href: "/" }, { label: "Projeler" }]}
    />

    <section class="px-margin-mobile py-section-gap md:px-margin-desktop">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-gutter md:grid-cols-2">
        {
          projects.map((project, i) => (
            <a
              href={`/projeler/${project.slug}`}
              class="reveal group block"
              style={`transition-delay: ${i * 120}ms;`}
            >
              <div class="mb-6 h-[420px] overflow-hidden bg-surface-container">
                {project.image ? (
                  <img
                    src={project.image}
                    alt={project.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-graphite to-steel-blue text-white/30">
                    <Icon name="building" class="size-16" />
                  </div>
                )}
              </div>
              <p class="text-label uppercase tracking-widest text-vibrant-steel-blue">
                {project.category} · {project.year}
              </p>
              <h2 class="mt-2 text-body-lg font-bold text-primary">
                {project.title}, {project.location}
              </h2>
              <p class="mt-2 text-on-surface-variant">{project.summary}</p>
            </a>
          ))
        }
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Layout>
