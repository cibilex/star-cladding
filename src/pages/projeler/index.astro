---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Contact from "@/components/sections/Contact.astro";
import PageHero from "@/components/PageHero.astro";
import Icon from "@/components/Icon.astro";
import { Image } from "astro:assets";
import { projects } from "@/data/site";
import { resolveImage } from "@/data/images";
---

<Layout
  title="Projelerimiz | STAR ALÜMİNYUM"
  description="Tamamladığımız cam cephe, kompozit panel ve korkuluk projeleri. Star Alüminyum referansları."
>
  <Header />
  <main>
    <PageHero
      kicker="Referanslarımız"
      title="Projelerimiz"
      subtitle="Tamamladığımız cephe işlerinden bir seçki. Her proje, milimetrik hassasiyetle hayata geçirildi."
      crumbs={[{ label: "Anasayfa", href: "/" }, { label: "Projeler" }]}
    />

    <section class="px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-gutter md:grid-cols-2">
        {
          projects.map((project, i) => {
            const img = resolveImage(project.image);
            return (
            <a
              href={`/projeler/${project.slug}`}
              class="reveal group block"
              style={`transition-delay: ${i * 120}ms;`}
            >
              <div class="relative mb-6 h-[420px]">
                <div
                  class="absolute inset-0 translate-x-3 translate-y-3 border border-vibrant-steel-blue/40 transition-transform duration-500 group-hover:translate-x-1.5 group-hover:translate-y-1.5"
                  aria-hidden="true"
                >
                </div>
                <div class="relative h-full w-full overflow-hidden bg-surface-container">
                  {img ? (
                    <Image
                      src={img}
                      alt={`${project.title} — ${project.category}`}
                      widths={[480, 800, 1200]}
                      sizes="(min-width: 768px) 50vw, 100vw"
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-graphite to-steel-blue text-white/30">
                      <Icon name="building" class="size-16" />
                    </div>
                  )}
                  <span class="absolute left-5 top-5 border border-white/25 bg-primary/70 px-3 py-1.5 text-label uppercase tracking-widest text-white backdrop-blur-sm">
                    {project.category}
                  </span>
                </div>
              </div>
              <h2 class="text-body-lg font-bold text-primary">
                {project.title}, {project.location}
              </h2>
              <p class="mt-1 text-label uppercase tracking-widest text-on-surface-variant">
                {project.location} · {project.year}
              </p>
              <p class="mt-2 text-on-surface-variant">{project.summary}</p>
            </a>
            );
          })
        }
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Layout>
