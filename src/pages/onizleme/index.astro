---
/**
 * Dev-only hub for the section variant previews. noindex; deleted after the
 * final variants are picked.
 */
import Layout from "@/layouts/Layout.astro";

const pages = [
  { href: "/onizleme/iletisim", label: "İletişim", count: 3 },
];
// Seçilen kazananlar anasayfada canlı:
// - Müşteri Yorumları: Marquee Wall (tek satır)
// - Projeler: Cinematic Rail
// - Hizmetler: Bento Mosaic (sections/Services.astro)
---

<Layout title="Önizleme | Bölüm Varyantları" noindex>
  <main class="mx-auto max-w-3xl px-margin-mobile py-24">
    <p class="text-label uppercase tracking-widest text-vibrant-steel-blue">
      Dev Önizleme
    </p>
    <h1 class="mt-2 font-display text-headline text-primary">
      Bölüm Varyantları
    </h1>
    <p class="mt-4 text-on-surface-variant">
      Her sayfada o bölümün varyantları alt alta, etiketli olarak listelenir.
      Final seçildikten sonra bu sayfalar silinir.
    </p>
    <ul class="mt-10 space-y-4">
      {
        pages.map((p) => (
          <li>
            <a
              href={p.href}
              class="flex items-center justify-between rounded-xl border border-outline-variant bg-surface-container-low px-6 py-5 font-display font-bold text-primary transition hover:border-vibrant-steel-blue hover:shadow-md"
            >
              {p.label}
              <span class="text-sm font-normal text-on-surface-variant">
                {p.count} varyant →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
