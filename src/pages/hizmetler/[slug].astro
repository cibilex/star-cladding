---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Contact from "@/components/sections/Contact.astro";
import ServiceHero from "@/components/ServiceHero.astro";
import RelatedProjects from "@/components/RelatedProjects.astro";
import Icon from "@/components/Icon.astro";
import { company, services } from "@/data/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.slug !== service.slug);
---

<Layout
  title={`${service.title} | STAR ALÜMİNYUM`}
  description={service.summary}
>
  <Header />
  <main>
    <ServiceHero service={service} />

    <!-- description + feature check-cards + sticky quote aside -->
    <section class="px-margin-mobile py-section-gap md:px-margin-desktop">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-16 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <p class="reveal text-body-lg leading-relaxed text-on-surface-variant">
            {service.description}
          </p>

          <h2 class="reveal mb-8 mt-16 text-headline text-primary">
            Öne Çıkanlar
          </h2>
          <div class="grid grid-cols-1 gap-gutter md:grid-cols-2">
            {
              service.features.map((feature, i) => (
                <div
                  class="reveal group flex items-start gap-4 rounded-lg border border-outline-variant bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-vibrant-steel-blue hover:shadow-[0_8px_30px_rgba(45,90,136,0.15)]"
                  style={`transition-delay: ${i * 100}ms;`}
                >
                  <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-vibrant-steel-blue/10 text-vibrant-steel-blue transition-colors duration-300 group-hover:bg-vibrant-steel-blue group-hover:text-white">
                    <Icon name="check-circle" class="size-5" />
                  </span>
                  <p class="pt-2 font-semibold text-on-surface">{feature}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="lg:col-span-5">
          <!-- gradient-ring quote card -->
          <div
            class="reveal sticky top-28 rounded-lg bg-gradient-to-br from-vibrant-steel-blue via-outline-variant to-steel-blue p-px shadow-xl shadow-vibrant-steel-blue/10"
          >
            <div class="rounded-[7px] bg-white p-8 md:p-10">
              <p class="mb-2 text-label font-semibold uppercase tracking-widest text-vibrant-steel-blue">
                Ücretsiz Keşif ve Teklif
              </p>
              <h3 class="mb-4 text-headline text-primary">
                Projenizi birlikte planlayalım
              </h3>
              <p class="mb-8 text-on-surface-variant">
                Ölçü, malzeme ve süre planını netleştirmek için ücretsiz keşif
                ve fiyat teklifi sunuyoruz. Bize ulaşın, projenizi birlikte
                değerlendirelim.
              </p>

              <div class="mb-8 space-y-4">
                <a
                  href={company.phoneHref}
                  class="flex items-center gap-3 font-semibold text-primary transition-colors hover:text-vibrant-steel-blue"
                >
                  <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-surface-container text-vibrant-steel-blue">
                    <Icon name="phone" class="size-4" />
                  </span>
                  {company.phone}
                </a>
                <a
                  href={company.whatsapp}
                  target="_blank"
                  rel="noopener"
                  class="flex items-center gap-3 font-semibold text-primary transition-colors hover:text-vibrant-steel-blue"
                >
                  <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-surface-container text-vibrant-steel-blue">
                    <Icon name="message-circle" class="size-4" />
                  </span>
                  WhatsApp'tan yazın
                </a>
              </div>

              <a
                href="#iletisim"
                class="shimmer-btn flex w-full items-center justify-center gap-2 rounded-sm bg-vibrant-steel-blue px-8 py-4 text-label font-semibold uppercase tracking-widest text-white shadow-xl transition-all hover:-translate-y-0.5 hover:shadow-[0_0_20px_rgba(45,90,136,0.6)]"
              >
                TEKLİF AL
                <Icon name="arrow-right" class="size-4" />
              </a>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <RelatedProjects serviceSlug={service.slug} serviceTitle={service.title} />

    <!-- other services: compact rows -->
    <section class="px-margin-mobile py-24 md:px-margin-desktop">
      <div class="mx-auto max-w-7xl">
        <p class="reveal mb-2 text-label font-semibold uppercase tracking-widest text-vibrant-steel-blue">
          Hizmetler
        </p>
        <h2 class="reveal mb-10 text-headline text-primary" style="transition-delay: 80ms;">
          Diğer Hizmetlerimiz
        </h2>
        <div class="divide-y divide-outline-variant border-y border-outline-variant">
          {
            others.map((s, i) => (
              <a
                href={`/hizmetler/${s.slug}`}
                class="reveal group flex items-center gap-5 py-6"
                style={`transition-delay: ${i * 100}ms;`}
              >
                <Icon
                  name={s.icon}
                  class="size-7 shrink-0 text-graphite transition-colors group-hover:text-vibrant-steel-blue"
                />
                <div class="min-w-0 flex-1">
                  <h3 class="font-bold text-primary transition-colors group-hover:text-vibrant-steel-blue">
                    {s.title}
                  </h3>
                  <p class="truncate text-on-surface-variant">{s.summary}</p>
                </div>
                <Icon
                  name="arrow-right"
                  class="size-5 shrink-0 text-aluminum-silver transition-all group-hover:translate-x-1 group-hover:text-vibrant-steel-blue"
                />
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Layout>
