---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Contact from "@/components/sections/Contact.astro";
import PageHero from "@/components/PageHero.astro";
import Icon from "@/components/Icon.astro";
import { Button } from "@/components/ui/button";
import { services } from "@/data/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.slug !== service.slug);
---

<Layout
  title={`${service.title} | STAR ALÜMİNYUM`}
  description={service.summary}
>
  <Header />
  <main>
    <PageHero
      kicker="Hizmet"
      title={service.title}
      crumbs={[
        { label: "Anasayfa", href: "/" },
        { label: "Hizmetler", href: "/hizmetler" },
        { label: service.title },
      ]}
    />

    <section class="px-margin-mobile py-section-gap md:px-margin-desktop">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-16 md:grid-cols-12">
        <div class="md:col-span-7">
          <Icon name={service.icon} class="mb-6 size-12 text-vibrant-steel-blue" />
          <p class="text-body-lg leading-relaxed text-on-surface-variant">
            {service.description}
          </p>

          <h2 class="mb-8 mt-16 text-headline text-primary">Öne Çıkanlar</h2>
          <ul class="space-y-5">
            {
              service.features.map((feature) => (
                <li class="flex items-start gap-4">
                  <Icon name="check-circle" class="size-6 shrink-0 text-vibrant-steel-blue" />
                  <span class="text-on-surface-variant">{feature}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <aside class="md:col-span-5">
          <div class="sticky top-28 bg-surface-container-low p-10">
            <h3 class="mb-4 text-body-lg font-bold text-primary">
              Bu hizmet için teklif alın
            </h3>
            <p class="mb-8 text-on-surface-variant">
              Projenizi birlikte değerlendirelim. Ücretsiz keşif ve fiyat teklifi
              için bizimle iletişime geçin.
            </p>
            <a href="/#iletisim">
              <Button variant="accent" size="lg" className="w-full shimmer-btn">
                TEKLİF AL
              </Button>
            </a>
          </div>
        </aside>
      </div>
    </section>

    <!-- other services -->
    <section class="bg-surface px-margin-mobile py-24 md:px-margin-desktop">
      <div class="mx-auto max-w-7xl">
        <h2 class="mb-12 text-headline text-primary">Diğer Hizmetler</h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          {
            others.map((s) => (
              <a
                href={`/hizmetler/${s.slug}`}
                class="group flex items-center gap-6 border border-outline-variant p-8 transition-colors hover:border-vibrant-steel-blue"
              >
                <Icon
                  name={s.icon}
                  class="size-9 shrink-0 text-graphite transition-colors group-hover:text-vibrant-steel-blue"
                />
                <div>
                  <h3 class="font-bold text-primary">{s.title}</h3>
                  <p class="text-on-surface-variant">{s.summary}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Layout>
